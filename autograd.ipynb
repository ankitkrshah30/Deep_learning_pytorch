   "source": [
    "import math\n",
    "def dy_dx(x):\n",
    "    return 2*x\n",
    "def dz_dy(y):\n",
    "    return math.cos(y)\n",
    "def du_dz(z):\n",
    "    return math.exp(z)\n",
    "def du_dx(x):\n",
    "    y=x**2\n",
    "    z=math.sin(y)\n",
    "    return dy_dx(x)*dz_dy(y)*du_dz(z)\n",
    "#y=x^2\n",
    "#z=sin y\n",
    "#u=e^z\n",
    "du_dx(2)"
   ]
